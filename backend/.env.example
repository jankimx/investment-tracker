# Copy this file to .env and fill in your values
# Get MONGO_URI from MongoDB Atlas: https://cloud.mongodb.com

MONGO_URI=mongodb+srv://USERNAME:PASSWORD@cluster0.XXXXX.mongodb.net/?retryWrites=true&w=majority
DB_NAME=investment_tracker

# REQUIRED -- the app refuses to start without this. Pick something long and random.
APP_PASSWORD=

FLASK_ENV=development
PORT=5000

# Optional integrations
FMP_API_KEY=
ANTHROPIC_API_KEY=
RESEND_API_KEY=
NOTIFY_VERIZON=
NOTIFY_ATT=
APP_URL=
